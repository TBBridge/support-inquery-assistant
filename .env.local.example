# ============================================================
# 問い合わせ支援 AI アシスタント - 環境変数設定
# このファイルをコピーして .env.local を作成してください
# cp .env.local.example .env.local
# ============================================================

# ---- Anthropic Claude API ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Voyage AI (Embeddings) ----
# https://dash.voyageai.com/ でAPIキーを取得
VOYAGEAI_API_KEY=pa-...

# ---- Vercel Postgres (pgvector) ----
# Vercel Dashboard > Storage > Create Database > Postgres
# 作成後に自動的に設定されます（Vercel環境）
# ローカル開発時は .env.local に手動設定
POSTGRES_URL=postgresql://...
POSTGRES_PRISMA_URL=postgresql://...?pgbouncer=true
POSTGRES_URL_NO_SSL=postgresql://...
POSTGRES_URL_NON_POOLING=postgresql://...
POSTGRES_USER=default
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=verceldb

# ---- NextAuth.js ----
# ランダムな文字列を生成: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Google OAuth
# https://console.cloud.google.com/ でOAuth 2.0クライアントを作成
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ---- MCP API Key (オプション) ----
# MCP HTTP エンドポイントへのアクセス制御
# 設定しない場合はオープンアクセス（開発時のみ推奨）
MCP_API_KEY=your-mcp-api-key
