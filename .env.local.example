# ============================================================
# 問い合わせ支援 AI アシスタント - 環境変数設定
# このファイルをコピーして .env.local を作成してください
# cp .env.local.example .env.local
# ============================================================

# ---- Anthropic Claude API ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Voyage AI (Embeddings) ----
# https://dash.voyageai.com/ でAPIキーを取得
VOYAGEAI_API_KEY=pa-...

# ---- Supabase (PostgreSQL + pgvector) ----
# https://supabase.com → プロジェクト → Settings → Database → Connection string
# Transaction pooler (ポート 6543) を使用 ※ サーバーレス/Vercel 環境向け
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---- NextAuth.js ----
# ランダムな文字列を生成: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Google OAuth
# https://console.cloud.google.com/ でOAuth 2.0クライアントを作成
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ---- MCP API Key (オプション) ----
# MCP HTTP エンドポイントへのアクセス制御
# 設定しない場合はオープンアクセス（開発時のみ推奨）
MCP_API_KEY=your-mcp-api-key
